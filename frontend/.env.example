# Firebase Cloud credentials for AgriShield
# Copy this file to .env and fill in your values
# On Netlify, add these as Environment Variables in Site Settings > Environment Variables

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend API Endpoint URL (optional, defaults to http://localhost:8000 for local dev)
VITE_API_URL=https://your-backend-api-url.com
